	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login as Stakeholder",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Save access token to collection variable",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"access_token\", jsonData.access_token);",
									"    console.log(\"Access token saved:\", jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{stakeholder_email}}\",\n    \"password\": \"{{stakeholder_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Login as stakeholder user to get access token"
					},
					"response": []
				}
			],
			"description": "Authentication endpoints"
		},
